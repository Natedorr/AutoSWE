{
  "_comment": "Named harness profiles for coding phases (plan, fix, review). Copy to harnesses.json (gitignored) and edit. Reference a profile from repos.json using plan_harness, fix_harness, or review_harness. Keys starting with _ are skipped.",

  "claude-opus": {
    "backend": "claude_code",
    "model": "claude-opus-4-8"
  },

  "claude-sonnet": {
    "backend": "claude_code",
    "model": "claude-sonnet-4-6"
  },

  "claude-haiku": {
    "backend": "claude_code",
    "model": "claude-haiku-4-5-20251001"
  },

  "ollama-local": {
    "_comment": "Claude Code with a local Ollama provider — requires Ollama running on localhost",
    "backend": "claude_code",
    "model": "sonnet",
    "anthropic_base_url": "http://localhost:11434",
    "anthropic_auth_token": "ollama"
  },

  "codex-gpt5": {
    "_comment": "OpenAI Codex with GPT-5 — requires 'codex' CLI on PATH and CODEX_API_KEY (or openai_api_key as fallback)",
    "backend": "codex",
    "model": "gpt-5",
    "codex_api_key": "${CODEX_API_KEY}"
  },

  "codex-gpt5-codex": {
    "_comment": "Alternative: use codex_api_key instead of openai_api_key (maps to CODEX_API_KEY env var)",
    "backend": "codex",
    "model": "gpt-5-codex",
    "codex_api_key": "${CODEX_API_KEY}"
  },

  "codex-4o": {
    "_comment": "OpenAI Codex with GPT-4o — cheaper, faster, good for plan/review phases",
    "backend": "codex",
    "model": "gpt-4o",
    "openai_api_key": "${OPENAI_API_KEY}"
  },

  "ollama-codex": {
    "_comment": "Local Codex with Ollama — uses ~/.codex/config.toml for model provider config. No API key needed.",
    "backend": "codex",
    "model": "qwen3.6:27b"
  },

  "codex-custom": {
    "_comment": "Codex with custom model, timeout, and API base — for self-hosted OpenAI-compatible endpoints",
    "backend": "codex",
    "model": "custom-model",
    "openai_api_key": "${CUSTOM_API_KEY}",
    "timeout": 3600
  }
}
