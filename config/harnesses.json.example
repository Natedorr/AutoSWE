{
  "_comment": "Named harness profiles for coding phases (plan, fix, review). Reference a profile from repos.json using plan_harness, fix_harness, or review_harness. Keys starting with _ are skipped.",

  "claude-opus": {
    "backend": "claude_code",
    "model": "claude-opus-4-8"
  },

  "claude-sonnet": {
    "backend": "claude_code",
    "model": "claude-sonnet-4-6"
  },

  "claude-haiku": {
    "backend": "claude_code",
    "model": "claude-haiku-4-5-20251001"
  },

  "ollama-local": {
    "backend": "claude_code",
    "model": "sonnet",
    "anthropic_base_url": "http://localhost:11434",
    "anthropic_auth_token": "ollama"
  },

  "codex-gpt5": {
    "_comment": "Phase 4 — requires 'codex' CLI on PATH and OPENAI_API_KEY",
    "backend": "codex",
    "model": "gpt-5",
    "api_key_env": "OPENAI_API_KEY"
  }
}
