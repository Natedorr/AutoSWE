# autoSWE Poller configuration (Claude Code integration)
# Supports GitHub and Azure DevOps repos (configured in repos.json).
# Copy this file to autoswe.env and fill in your values.
# Repository credentials (PATs) live in config/repos.json — one "pat" per entry.

# Max simultaneous agent jobs
MAX_CONCURRENT=1
# Max restart attempts per issue before failing (user must /retry to continue)
MAX_ATTEMPTS=3
# Max total time per issue in hours before failing (user must /retry to continue)
MAX_TOTAL_HOURS=2
# Max agent runtime in seconds (2 hours)
AGENT_TIMEOUT=7200
# Retry agent on timeout or SDK error (0 = no retry, 1 = retry once). Useful for Ollama which
# unloads the model after idle, causing SIGTERM (exit 143) on long runs.
AGENT_RETRY_ON_FAILURE=0
# Worktrees directory (relative to AUTOSWE_DIR, or absolute)
WORKTREE_DIR=worktrees
# If true: suppress welcome comments; only post completion comments
SILENT_REPORTING=false
# If true: auto-assign issues to the authenticated user
AUTO_ASSIGN=true
# Override assignee (defaults to token owner if blank)
ASSIGN_USER=
# If true: automatically open a PR when /fix completes successfully
AUTO_CREATE_PR=false

# Claude Code settings (per-repo overrides in config/repos.json win)
CLAUDE_CLI_PATH=
PLAN_MODEL=
FIX_MODEL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
